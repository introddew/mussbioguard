# Environment Variables - MUSSBIO-GUARD Dashboard
# Salin file ini menjadi .env dan isi nilainya

# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── MQTT Broker ──────────────────────────────────────
# Broker publik (untuk testing tanpa konfigurasi tambahan)
MQTT_BROKER=mqtt://broker.emqx.io:1883
# Atau gunakan HiveMQ publik:
# MQTT_BROKER=mqtt://broker.hivemq.com:1883

MQTT_TOPIC=mussbio/sensor/data

# ─── Threshold Frekuensi (Hz) ────────────────────────
# f1: Batas bawah WASPADA
THRESHOLD_F1=15.2
# f2: Batas bawah KRITIS
THRESHOLD_F2=22.4

# ─── Telegram Bot (opsional) ──────────────────────────
# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=8950375651:AAE93CpZvN0VqwXkQwNVlxcqP2J1mTiV_qo
# Dapatkan dari @userinfobot atau forward pesan ke bot
TELEGRAM_CHAT_ID=2038330521
